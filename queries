-- 1- Raio-X da Carteira de Crédito: Qual é o volume total (em R$) de crédito concedido (valor principal) por tipo de produto? Ordene do maior para o menor.
select pf.tipo_produto, sum(valor_principal) as volume_total_R$ from contratos_credito cc

join produtos_financeiros pf on cc.id_produto = pf.id_produto

group by pf.tipo_produto
order by sum(valor_principal) desc;


-- 2- Perfil de Renda: Qual é a renda média declarada dos clientes, agrupada por tipo_pessoa (PF vs PJ)?
select tipo_pessoa, 
round(avg(renda_declarada), 2) as renda_media
from clientes

where renda_declarada is not null

group by tipo_pessoa;


-- 3- Engajamento de Contas: Liste o nome dos clientes, o tipo de conta, o saldo atual e a quantidade de transações que cada conta já realizou. Inclua contas que não possuem transações.
select c.nome, ct.tipo_conta, ct.saldo_atual, count(ts.id_transacao) as qtde_transacoes 
from clientes c

join contas ct on c.id_cliente = ct.id_cliente
left join transacoes ts on ct.id_conta = ts.id_conta

group by  c.nome, ct.id_conta, ct.tipo_conta, ct.saldo_atual
order by c.nome;


-- 4- Performance Comercial: Quais são os 3 funcionários (gerentes) que mais aprovaram valor em contratos de crédito? Mostre o nome, a agência e o volume total aprovado.
select f.nome, a.nome_agencia, sum(cc.valor_principal) as total_aprovado from funcionarios f

join agencias a on f.id_agencia = a.id_agencia
join contratos_credito cc on f.id_funcionario = cc.id_funcionario

WHERE LOWER(f.cargo) LIKE '%gerente%'

group by f.id_funcionario, f.nome, a.nome_agencia
order by total_aprovado  desc
limit 3;

-- 5- Visão de Risco Básica: Quantos contratos ativos estão classificados como 'Inadimplente' e qual a soma do valor principal atrelado a eles?
select count(cc.id_contrato) as qtdeContratos, sum(cc.valor_principal) from contratos_credito cc 

where status_contrato = 'Inadimplente';


-- 6- Indicador de Inadimplência Bruta: Qual o percentual de parcelas atrasadas em relação ao total de parcelas geradas no banco? 
select round(sum(case when p.status_parcela = 'Atrasada' then 1 else 0 end)
 /
nullif(count(p.id_parcela), 0) * 100.00, 2) as percentual
 from parcelas p;
 
 
-- 7- Score de Comprometimento de Renda: Para clientes pessoa física (PF), calcule o valor total de suas parcelas (somando todos os contratos ativos) e divida pela sua renda declarada para encontrar o "% de comprometimento mensal".
--  Liste os clientes que têm mais de 30% da renda comprometida.
select c.nome, substr(pl.data_vencimento, 1, 7) as ano_mes,
round(sum(pl.valor_parcela) * 100.00
 /
 nullif(c.renda_declarada, 0), 2)  as total_mes
from clientes c

join contratos_credito cc on c.id_cliente = cc.id_cliente
join parcelas pl on cc.id_contrato = pl.id_contrato

where c.tipo_pessoa = 'PF'
and cc.status_contrato = 'Ativo'

group by c.id_cliente, c.nome, substr(pl.data_vencimento, 1, 7), c.renda_declarada
having total_mes > 30.0



-- 8- Análise de Faturas vs Saldo: Encontre os clientes cujas faturas de cartão de crédito estão com o status Fechada_Atrasada e verifique qual é o saldo atual de suas contas correntes correspondentes.

select distinct cl.nome, c.saldo_atual from clientes cl

join contas c on cl.id_cliente = c.id_cliente
join cartoes ct on cl.id_cliente= ct.id_cliente 
join faturas_cartao fc on ct.id_cartao = fc.id_cartao 

where fc.status_fatura = 'Fechada_Atrasada' 
and c.tipo_conta = 'Corrente';


-- 9- Segmentação de Clientes (Tiers): Classifique todos os clientes nas categorias A, B ou C usando um CASE STATEMENT baseado na soma do saldo das suas contas + o limite total de seus cartões de crédito. 
-- (> R$100k = A, entre R$20k e R$100k = B, < R$20k = C).

with total_conta as (
select c.id_cliente, c.nome, sum(co.saldo_atual)  as total_co
from clientes c
left join contas co on c.id_cliente = co.id_cliente

group by c.id_cliente, c.nome
),

total_cartao as (
    select c.id_cliente, sum(c.limite_credito) as total_li
    from cartoes c
    group by c.id_cliente
)

select tc.id_cliente, tc.nome, tc.total_co + coalesce(tct.total_li, 0) as total,
case
when tc.total_co + coalesce(tct.total_li, 0) < 20000 then 'C'
when tc.total_co + coalesce(tct.total_li, 0) >= 20000 and tc.total_co + coalesce(tct.total_li, 0) <= 100000 then 'B'
else 'A'
end as classificacao
from total_conta tc

left join total_cartao tct on tc.id_cliente = tct.id_cliente

order by total asc;

-- 10 -Comportamento Transacional de Crédito vs Débito: Descubra qual cliente pessoa jurídica (PJ) teve a maior diferença absoluta entre transações de "Crédito" e "Débito" (Entradas - Saídas) em todo o histórico de transações.
select c.nome, 
abs(
sum(case when tipo_movimento = 'Credito' then valor else 0 end)
-
sum(case when tipo_movimento = 'Debito' then valor else 0 end)) as total_abs
from clientes c

join contas ct on c.id_cliente = ct.id_cliente
join transacoes t on ct.id_conta = t.id_conta 

where c.tipo_pessoa = 'PJ'

group by c.id_cliente, c.nome
order by total_abs desc
limit 1;

-- 11- Análise de Safra (Cohort de Originação): Considerando a data de contratação de crédito, agrupe os contratos por mês e ano (Safra).
--  Para cada safra, mostre o volume total concedido e use a função LAG() para calcular a variação percentual de crescimento (ou queda) em relação ao mês anterior.

with soma as (
select substr(data_contratacao,1, 7) as data, sum(valor_principal) as total
 from contratos_credito
 
 group by substr(data_contratacao,1, 7)
 )
 
 select *,
 round((total - (lag(total) over (order by data asc)))
  / nullif(lag(total) over (order by data asc),0) * 100.00, 2)
 from soma;


-- 12- Rolling Average de Transações: Para a conta do cliente "Tech Solutions Ltda", calcule a média móvel (rolling average) do valor transacionado (apenas transações de Crédito) 
-- usando as últimas 3 transações de forma cronológica, exibindo linha a linha usando window functions.
select c.nome, t.data_hora_transacao, t.valor,
round(avg(valor) over (partition by ct.id_conta order by data_hora_transacao asc ROWS BETWEEN 2 PRECEDING AND CURRENT ROW),2) as rolling_average
 from clientes c

join contas ct on c.id_cliente = ct.id_cliente 
join transacoes t on ct.id_conta = t.id_conta

where c.id_cliente = 3
and t.tipo_movimento = 'Credito';

-- 13- Identificação de "Risco de Fuga" (Churn Risk): Identifique os clientes que possuem um limite de cartão de crédito alto (acima da média geral do banco),
--  mas que o saldo de suas faturas nos últimos 2 meses registrados foi menor que 10% do seu limite disponível. (Exige CTEs e cruzamento entre faturas e limites).

with media_banco  as (
select round(avg(limite_credito),2) as media_geral from cartoes 
),

por_mes as (
select c.id_cliente, c.nome, fc.valor_total, substr(fc.data_vencimento, 1, 7), ct.limite_credito,
row_number() over (partition by c.id_cliente order by fc.data_vencimento desc) as ranke
 from  clientes c
join cartoes ct on c.id_cliente = ct.id_cliente
join faturas_cartao fc on ct.id_cartao = fc.id_cartao
),

soma_parcelas as (
select id_cliente, nome, limite_credito,
sum(valor_total) as total
 from por_mes

where ranke <=2

GROUP BY id_cliente, nome, limite_credito
)

select * from soma_parcelas, media_banco

where limite_credito > media_geral
and total < (limite_credito * 0.10);

-- 14- Tempo até a Primeira Falha (Time-to-Default): Calcule a média de dias que os contratos que estão atualmente 'Inadimplentes' levaram entre a data_contratacao e a data da primeira parcela com status 'Atrasada'. 
-- (Exige encontrar a data mínima de atraso por contrato).

with contratacao as (
select cc.id_contrato, cc.data_contratacao as datas from contratos_credito cc

where cc.status_contrato = 'Inadimplente'
),

primeiro_atraso as (
select cc.id_contrato, min(p.data_vencimento) datas_p from contratos_credito cc

join parcelas p on cc.id_contrato = p.id_contrato

where p.status_parcela = 'Atrasada'

group by cc.id_contrato
),

calculo_dias as (
select cc.id_contrato, datediff(p.datas_p, cc.datas) as dias from contratacao cc
join primeiro_atraso p on cc.id_contrato = p.id_contrato
)

select 
round(avg(dias), 2) as dias
 from calculo_dias;
 
 
-- 15- Curva ABC (Pareto) de Receita de Cartões: Identifique os clientes que geram a maior receita de cartão (valor da fatura). Usando window functions, calcule a soma acumulada percentual (% Acumulado) das faturas geradas,
--  ordenando do maior para o menor gerador, para provar se a regra 80/20 se aplica a este portfólio de cartões.

with soma_total as (
select c.id_cliente, 
sum(fc.valor_total) as total
 from faturas_cartao fc
 
 join cartoes ct on fc.id_cartao = ct.id_cartao
 join clientes c on ct.id_cliente = c.id_cliente
 
 group by c.id_cliente
 ),
 
 acumulado as (
select id_cliente, total,
sum(total) over (order by total desc) as acumulado,
sum(total) over () as total_geral
 from soma_total 
)

select id_cliente, total, acumulado,
round((acumulado / total_geral) * 100.00, 2) as percentual_acumulado
 from acumulado;

-- 16. Auditoria de Compliance (Inconsistências):
-- A área de risco detectou uma possível falha de sistema. Liste os clientes que possuem a conta corrente com o status_conta igual a 'Bloqueada' ou 'Inativa', 
-- mas que ainda possuem faturas de cartão de crédito com o status 'Aberta'. Retorne o nome do cliente, o status da conta e o valor da fatura.

select 
c.nome,
ct.status_conta,
fc.valor_total
 from clientes c

join contas ct 
on c.id_cliente = ct.id_cliente

join cartoes cts 
on ct.id_conta = cts.id_conta

join faturas_cartao fc 
on cts.id_cartao = fc.id_cartao

where 
(ct.tipo_conta = 'Corrente')
and
(fc.status_fatura = 'Aberta') 
and 
ct.status_conta in('Bloqueada', 'Inativa');


-- 17. Conversão de Onboarding (Time-to-Credit):
-- Queremos saber quão rápido os clientes novos tomam crédito. Calcule o percentual de clientes que contrataram seu primeiro empréstimo (qualquer produto em contratos_credito) em até 30 dias após a data_abertura de suas contas.

with clientes30dias as (
select c.nome,
datediff(min(cc.data_contratacao), min(ct.data_abertura)) as dias
 from clientes c 

join contas ct on c.id_cliente = ct.id_cliente
join contratos_credito cc on ct.id_conta = cc.id_conta

group by c.id_cliente, c.nome
)

select 
sum(case when dias <= 30 then 1 else 0 end) * 100.0 / count(*)
 from  clientes30dias;
 
 
--  18. Clientes "Superavitários" (Garantia Natural):
-- Encontre os clientes cujo saldo em conta corrente/poupança (saldo_atual) é maior do que a soma de toda a sua dívida pendente (soma das parcelas com status 'Pendente' ou 'Atrasada'). 
-- Liste o nome, o saldo total em conta e o saldo devedor.

with dividas_clientes as (
select c.id_cliente, c.nome, sum(p.valor_parcela) as dividas 
 from clientes c

join contratos_credito cc on c.id_cliente = cc.id_cliente
join parcelas p on cc.id_contrato = p.id_contrato

where p.status_parcela in ('Pendente', 'Atrasada')
group by c.id_cliente, c.nome
), 

total_saldo as (
select c.id_cliente, c.nome, sum(ct.saldo_atual) as saldo

 from clientes c

join contas ct on c.id_cliente = ct.id_cliente


where ct.tipo_conta in ('Corrente', 'Poupanca')

group by c.id_cliente, c.nome
)

select ts.nome, ts.saldo, dc.dividas
 from total_saldo ts

left join dividas_clientes dc on ts.id_cliente = dc.id_cliente

where ts.saldo > coalesce(dc.dividas,0);

-- 19. Sucesso de Cross-Selling (PJ):
-- A diretoria quer medir a penetração de múltiplos produtos no segmento corporativo. Identifique os clientes pessoa jurídica (tipo_pessoa = 'PJ') que possuem, simultaneamente,
--  um contrato ativo de 'Capital de Giro' (qualquer modalidade) E um cartão de crédito emitido.

select distinct c.nome, c.tipo_pessoa, pf.tipo_produto  from clientes c 

join contratos_credito cc on c.id_cliente = cc.id_cliente
join produtos_financeiros pf on cc.id_produto = pf.id_produto
join cartoes ct on c.id_cliente = ct.id_cliente

where c.tipo_pessoa = 'PJ'
and
pf.tipo_produto = 'Capital de Giro'
and
cc.status_contrato = 'Ativo';


-- 20. O Efeito Dominó da Inadimplência (Contágio):
-- Geralmente, o cliente atrasa o cartão antes de atrasar o empréstimo. Identifique os clientes que tiveram uma fatura de cartão classificada como Fechada_Atrasada e que, 
-- no intervalo de até 45 dias seguintes à data de vencimento dessa fatura, também tiveram uma parcela de contrato de crédito classificada como Atrasada.

with fatura_fechada as (
select c.id_cliente, c.nome, fc.data_vencimento from clientes c 

join cartoes ct on c.id_cliente = ct.id_cliente
join faturas_cartao fc on ct.id_cartao = fc.id_cartao

where fc.status_fatura = 'Fechada_Atrasada'
),

parcela_atrasada as (
select f.id_cliente, datediff(p.data_vencimento, f.data_vencimento) as dias  from fatura_fechada f

join contratos_credito cc on f.id_cliente = cc.id_cliente
join parcelas p on cc.id_contrato = p.id_contrato

where p.status_parcela = 'Atrasada' 
)

select distinct * from parcela_atrasada
where dias between 0 and 45;
